# ----- uazapi (substitui Baileys — ver ADR-001) ---------------------
# Sao apenas 2 credenciais reais da uazapi:

# URL base do servidor uazapi (com plano pago).
# Ex.: https://api.uazapi.com  ou  https://seu-subdominio.uazapi.com
UAZAPI_BASE_URL=

# Admin token: usado APENAS pelos endpoints de criacao/listagem de
# instancia (header `admintoken`). NAO usar em chamadas de send/webhook.
UAZAPI_ADMIN_TOKEN=

# OBS: a URL publica que recebe webhook da uazapi e composta
# automaticamente a partir de BACKEND_URL (ja existente acima):
#   ${BACKEND_URL}/uazapi/webhook/<secret-por-instancia>

# Timeout das chamadas HTTP a uazapi (default 30s).
UAZAPI_TIMEOUT_MS=30000
